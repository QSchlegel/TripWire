{
  "name": "tripwire",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/guard",
    "apps/web"
  ],
  "overrides": {
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "scripts": {
    "build": "npm run build --workspace @tripwire/guard && npm run build --workspace @tripwire/web",
    "build:guard": "npm run build --workspace @tripwire/guard",
    "build:web": "npm run build --workspace @tripwire/web",
    "test": "npm run test --workspace @tripwire/guard",
    "dev:web": "npm run dev --workspace @tripwire/web",
    "dev:guard": "npm run dev --workspace @tripwire/guard",
    "start": "npm run start --workspace @tripwire/web"
  }
}
