{
  "name": "@twire/guard",
  "version": "0.1.1",
  "description": "Edge and Node pre-tool-call guard hooks for agentic runtimes.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/QSchlegel/TripWire.git",
    "directory": "packages/guard"
  },
  "homepage": "https://tripwire.observer/",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "twire": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./policy": {
      "types": "./dist/policy/index.d.ts",
      "import": "./dist/policy/index.js"
    },
    "./anomaly": {
      "types": "./dist/anomaly/index.d.ts",
      "import": "./dist/anomaly/index.js"
    },
    "./adapters/openai": {
      "types": "./dist/adapters/openai.d.ts",
      "import": "./dist/adapters/openai.js"
    },
    "./adapters/langchain": {
      "types": "./dist/adapters/langchain.d.ts",
      "import": "./dist/adapters/langchain.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "optionalDependencies": {
    "pg": "^8.13.3"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.11",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
