{
  "name": "@twire/enclave",
  "version": "0.1.0",
  "description": "Handle-only key custody and wallet plugin runtime for TripWire.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/QSchlegel/TripWire.git",
    "directory": "packages/enclave"
  },
  "homepage": "https://tripwire.observer/",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./relay": {
      "types": "./dist/relay.d.ts",
      "import": "./dist/relay.js"
    },
    "./adapters/mesh-cardano": {
      "types": "./dist/adapters/mesh-cardano.d.ts",
      "import": "./dist/adapters/mesh-cardano.js"
    },
    "./adapters/mesh-bitcoin": {
      "types": "./dist/adapters/mesh-bitcoin.d.ts",
      "import": "./dist/adapters/mesh-bitcoin.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@meshsdk/bitcoin": "1.9.0-beta.98",
    "@meshsdk/core": "1.9.0-beta.101"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
