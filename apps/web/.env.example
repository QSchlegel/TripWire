# Postgres connection for Prisma
DATABASE_URL="postgresql://user:password@localhost:5432/tripwire"

# Cookie signing for pseudonymous profile continuity
TRIPWIRE_PROFILE_COOKIE_SECRET="change-me-profile-cookie-secret"
TRIPWIRE_PROFILE_COOKIE_NAME="tripwire_profile"

# Daily rotating challenge flag salt
TRIPWIRE_FLAG_SALT="change-me-flag-salt"

# Admin API key for RL candidate approvals and allowlist management
TRIPWIRE_ADMIN_API_KEY="change-me-admin-api-key"

# Hosted provider defaults (optional)
OPENAI_API_KEY=""
TRIPWIRE_OPENAI_MODEL="gpt-4.1-mini"

# Public API rate limits
TRIPWIRE_RATE_LIMIT_PER_MINUTE="60"
TRIPWIRE_RATE_LIMIT_PER_DAY="2000"
